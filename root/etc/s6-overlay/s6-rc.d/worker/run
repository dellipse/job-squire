#!/usr/bin/with-contenv bash
# shellcheck shell=bash
# Exactly one process so each scheduled slot fires once. Waits for web
# (depends.d/web) since web owns first-boot DB init and migrations, and the
# worker attaches to the same SQLite database.

cd /app || exit 1
export HOME=/config
exec s6-setuidgid abc python3 -m app.worker
