#!/usr/bin/with-contenv bash
# shellcheck shell=bash
# Aggregated container-level healthcheck: passes only when all three
# processes look alive -- web's /health, mcp's /health, and the worker's
# heartbeat file (the worker has no HTTP endpoint of its own).

python3 -c "
import urllib.request
urllib.request.urlopen('http://localhost:8000/health', timeout=5)
" || exit 1

python3 -c "
import os, urllib.request
port = os.environ.get('MCP_PORT', '9000')
urllib.request.urlopen(f'http://localhost:{port}/health', timeout=5)
" || exit 1

python3 -c "
import os, sys, time
path = os.path.join(os.environ.get('DATA_DIR', '/data'), '.worker_heartbeat')
sys.exit(0 if os.path.exists(path) and time.time() - os.path.getmtime(path) < 900 else 1)
" || exit 1
