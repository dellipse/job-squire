# Copy to data/.env and fill in. Never commit the real .env.
#
# Place the data/ folder next to docker-compose.yml (or wherever DATA_HOST_DIR points).
# The job-squire, job-squire-worker, and job-squire-mcp services all load this file.

# REQUIRED: random secret for signing sessions AND encrypting stored API keys.
# Generate:  python -c "import secrets; print(secrets.token_hex(32))"
# NOTE: changing this later invalidates saved provider/SMTP/Anthropic secrets (re-enter them).
SECRET_KEY=

# Admin account (you — the operator). ADMIN_PASSWORD is required.
ADMIN_USERNAME=admin
ADMIN_NAME=Admin
ADMIN_PASSWORD=

# Job seeker account — optional.
# Leave USER_PASSWORD blank (or remove these lines entirely) to run with only
# the admin account. The user account is only created when USER_PASSWORD is set.
USER_USERNAME=user
USER_NAME=User
USER_PASSWORD=

# Container user/group IDs. Controls which host user the app process runs as.
# Used both as build args (baked into the image) and at runtime via the "user:"
# directive in docker-compose.yml, so the process UID/GID always matches the
# owner of the files in DATA_HOST_DIR.
# Run `id -u` and `id -g` on your host to find the right values.
PUID=1000
PGID=1000

# Host directory for persistent data (SQLite DB + uploads), bind-mounted to /data
# in each container. Keeping it on local disk (not a Docker named volume) makes
# backups trivial: just copy this folder. Must exist and be writable by the
# container user (UID/GID matching PUID/PGID above).
DATA_HOST_DIR=./job-squire/data

# Sessions are served over HTTPS via a reverse proxy, so keep secure cookies on.
# IMPORTANT: if this is true but the proxy does not yet have TLS configured (so
# the browser receives the login page over plain HTTP), the browser will silently
# drop the Secure cookie, leaving the session empty and causing a CSRF error on
# login.  Set to false only for plain-HTTP local testing or while TLS is pending.
SESSION_COOKIE_SECURE=true

# Session cookie name. Each instance that shares a registrable domain (e.g.
# squire.example.com and other.example.com) must use a distinct name, or
# the instances will clobber each other's sessions and CSRF tokens.
# The app derives a safe default from INSTANCE_NAME automatically
# (e.g. INSTANCE_NAME=castelo → castelo_session), so explicit override is
# only needed when INSTANCE_NAME is not set or you want a specific name.
# SESSION_COOKIE_NAME=castelo_session

# Public URL of Job Squire (used in notification emails). Optional.
PUBLIC_URL=https://squire.yourdomain.com

# --- Automated search scheduler (the worker service) ---
# The schedule follows the JOB-SEARCH LOCATION's local time, derived automatically
# from the location set in the app (e.g. "Austin, TX" -> Central). The server's
# own clock/TZ is ignored for scheduling. To force a specific zone, set SCHEDULE_TZ
# to any IANA name (e.g. America/New_York); leave blank to auto-derive.
SCHEDULE_TZ=
# Run times (local to the location): 8am, 1pm, 5pm on weekdays.
SCHEDULE_WEEKDAY_HOURS=8,13,17
# One weekend run, mid-morning.
SCHEDULE_WEEKEND_HOURS=9
SCHEDULE_MINUTE=0
# Random delay added after the cron trigger fires before the search actually
# starts (1 minute to this many minutes). Spreads load and makes traffic less
# predictable to provider APIs.
SCHEDULE_OFFSET_MAX_MINUTES=20
# Seconds to pause between consecutive per-title API calls within a single run,
# to stay under providers' per-minute rate limits (random jitter added on top).
SEARCH_THROTTLE_SECONDS=60
# Hours to skip a provider after it returns a 503 outage error. Resumes
# automatically on the next scheduled run after the cooldown expires.
PROVIDER_COOLDOWN_HOURS=4
# Set to 1 to run one search immediately when the worker starts (handy to test).
RUN_ON_START=0

# --- Machine ingest API (external Claude push) ---
# Set a long random token to enable POST /api/ingest. Leave blank to disable.
# Generate:  python -c "import secrets; print(secrets.token_urlsafe(32))"
INGEST_API_KEY=

# --- MCP connector (AI analysis "MCP" mode) ---
# Public HTTPS base URL of the MCP service (the job-squire-mcp container behind a reverse proxy).
# Leave blank to disable MCP mode.
PUBLIC_MCP_URL=https://mcp-squire.yourdomain.com
# Hostname the MCP server allowlists for DNS-rebinding protection.
# Set to the public MCP hostname (same as PUBLIC_MCP_URL without the scheme).
PUBLIC_MCP_HOST=mcp-squire.yourdomain.com
# Port uvicorn listens on inside the MCP container.
MCP_PORT=9000

# --- Host port mappings (docker-compose Option A / standalone mode) ---
# These control which host ports the containers are published on.
# They are used by docker-compose for port binding, NOT inside the containers.
#
# IMPORTANT: docker-compose reads these from the SHELL environment or a root-level
# .env file (next to docker-compose.yml), NOT from this data/.env file. To override
# the defaults, either export them in your shell before running `docker compose up`,
# or create a .env at the compose root containing the lines you want to change.
#
# APP_HOST_PORT=8080    # Host port for the web app (proxied to container port 8000)
# MCP_HOST_PORT=9000    # Host port for the MCP server (proxied to container MCP_PORT)
#
# For multi-instance deployments: each instance needs a different APP_HOST_PORT,
# MCP_HOST_PORT, DATA_HOST_DIR, PUBLIC_URL, PUBLIC_MCP_URL, and SECRET_KEY.
# Run each instance with: docker compose -p <instance-name> up -d

# Optional knobs
# PORT=8000            # Web app dev-server port (local dev only, not used by gunicorn)
# DATA_DIR=/data
# MAX_UPLOAD_MB=10
# SESSION_DAYS=7
# CSRF_TIME_LIMIT=14400   # CSRF token lifetime in seconds (default 4h).
#                         # Set to 0 to disable expiry (tokens last the session).
# ALLOW_INSECURE=1   # Dev only: allows missing SECRET_KEY and passwords to default to
#                    # "changeme". Never set this in production.

# Set true for ONE boot to reset usernames, display names, and passwords to the values above,
# then remove it (or set back to false) before the next restart.
# RESET_UIDS_AND_PWDS_ON_START=false

# Job-source API keys and SMTP are entered in the app's Settings page,
# not here (they are encrypted in the database).
